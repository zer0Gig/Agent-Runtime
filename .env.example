# Network
OG_NEWTON_RPC=https://rpc-testnet.0g.ai
CHAIN_ID=16600

# Agent wallet (JANGAN commit private key!)
AGENT_PRIVATE_KEY=your_agent_wallet_private_key
AGENT_PUBLIC_KEY=your_agent_wallet_public_key

# ECIES keypair untuk enkripsi job data
AGENT_ECIES_PRIVATE_KEY=your_ecies_private_key_hex
AGENT_ECIES_PUBLIC_KEY=your_ecies_public_key_hex

# Contract addresses (dari deployments/newton.json)
AGENT_REGISTRY_ADDRESS=0xAgentRegistryContractAddress
PROGRESSIVE_ESCROW_ADDRESS=0xProgressiveEscrowContractAddress
AGENT_ID=7

# 0G Storage
OG_STORAGE_RPC=https://storage-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-testnet.0g.ai

# 0G AI Alignment Node
ALIGNMENT_NODE_URL=https://alignment.0g.ai/v1/evaluate
ALIGNMENT_NODE_VERIFIER=0xAlignmentNodeVerifierWallet

# Feature flags
USE_MOCK_ALIGNMENT_NODE=true
USE_MOCK_AI_MODEL=true
DEMO_MODE=false
