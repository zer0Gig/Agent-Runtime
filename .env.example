# ── 0G Network ───────────────────────────────────────
OG_NEWTON_RPC=https://evmrpc-testnet.0g.ai
CHAIN_ID=16602

# ── Agent Wallet (DO NOT commit private keys!) ──────
AGENT_PRIVATE_KEY=your_agent_wallet_private_key_without_0x
AGENT_ID=1

# ── ECIES Keypair (for encrypted job briefs) ────────
AGENT_ECIES_PRIVATE_KEY=your_ecies_private_key_hex
AGENT_ECIES_PUBLIC_KEY=your_ecies_public_key_hex

# ── Contract Addresses (Newton testnet — deployed)
AGENT_REGISTRY_ADDRESS=0x497CB366F87E6dbE2661B84A74FC8D0e3b9Ce78F
PROGRESSIVE_ESCROW_ADDRESS=0x61cd0a0031741844436dc5Dd5e7b92e75FD0Fba3
SUBSCRIPTION_ESCROW_ADDRESS=0x9d234C700D19C10a4ed6939d7fE04D0975d4ef78
USER_REGISTRY_ADDRESS=0x6cd15B8D866F8b19ea9310fD662809Dd7449bB81

# ── 0G Storage ──────────────────────────────────────
OG_STORAGE_RPC=https://rpc-storage-testnet.0g.ai
OG_INDEXER_RPC=https://indexer-storage-testnet-turbo.0g.ai

# ── 0G Alignment Node Verification ──────────────────
# For demo: use deployer private key to self-sign alignment scores
# In production: 0G Alignment Nodes sign evaluation results
ALIGNMENT_VERIFIER_KEY=your_deployer_private_key

# ── 0G Compute Network ─────────────────────────────
# SDK v0.6.x enforces hard minimums:
#   addLedger:    3 OG minimum  (first-time ledger creation)
#   transferFund: 1 OG minimum  (per provider)
# Total: fund agent wallet with at least 4 OG from https://faucet.0g.ai
# If ledger deposit < 3, runtime auto-routes to FALLBACK_LLM_PROVIDER.
OG_COMPUTE_LEDGER_DEPOSIT=3
OG_COMPUTE_PROVIDER_DEPOSIT=1

# Provider addresses (testnet):
# qwen-2.5-7b:  0xa48f01287233509FD694a22Bf840225062E67836
# gpt-oss-20b:  0x8e60d466FD16798Bec4868aa4CE38586D5590049
# gemma-3-27b:  0x69Eb5a0BD7d0f4bF39eD5CE9Bd3376c61863aE08

# ── Primary LLM Provider for agents ────────────────
# Options: 0g-compute, groq, openai, anthropic, google, alibaba, openrouter
# Set to groq (+ GROQ_API_KEY) for development without 4 OG in wallet.
# Set to 0g-compute for genuine decentralized inference (requires 4 OG).
FALLBACK_LLM_PROVIDER=groq

# API Keys for Standardized Providers
OPENAI_API_KEY=sk-your-openai-key
OPENROUTER_API_KEY=sk-or-your-openrouter-key
ALIBABA_API_KEY=sk-your-alibaba-key
GOOGLE_API_KEY=sk-your-google-key
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key
GROQ_API_KEY=gsk-your-groq-key

# ── Supabase (Skills Registry) ───────────────────────
# Same project URL/key as your frontend .env.local
# Required for pre-built skill resolution (F2 Skills Registry)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key

# ── Agent Activity Log (Frontend API URL) ────────────
# Set this to your deployed frontend URL so the agent can report progress to the UI
ACTIVITY_LOG_URL=http://localhost:3000/api/agent-activity

# ── Live Chat (Frontend integration) ─────────────────
# URL of the deployed frontend, used to POST chat messages to /api/job-chat
FRONTEND_URL=http://localhost:3000

# Optional auth token for securing the chat API endpoint.
# Generate a random string (e.g. `openssl rand -hex 32`) and set the same value
# in both the frontend and agent runtime. Leave blank to disable auth in dev.
AGENT_RUNTIME_TOKEN=

# ── Telegram Bot (optional — enables milestone notifications via Telegram) ──
# 1. Open Telegram → message @BotFather → /newbot → follow prompts → copy token
# 2. Paste token below
# 3. When a client connects their Telegram (via deep link), milestone cards will
#    be sent directly to their Telegram with Approve / Request Changes buttons.
# Leave blank to disable Telegram (dashboard chat still works).
TELEGRAM_BOT_TOKEN=
# TELEGRAM_WEBHOOK_URL=https://your-deployed-domain.com  # Uncomment for production
